# RepoClaude 环境配置模板
# 用法：cp .env.example .env，然后按需修改

# ── Core Daemon ───────────────────────────────────────────────
REPO_HOST=127.0.0.1
REPO_PORT=7437

# ── Logging ───────────────────────────────────────────────────
REPO_LOG_LEVEL=INFO
# 留空则仅输出 stderr，不写文件
REPO_LOG_FILE=~/.repo/logs/core.log
# text（人工可读键值对）或 json（结构化，适合日志聚合）
REPO_LOG_FORMAT=text

# ── Config File ───────────────────────────────────────────────
# REPO_CONFIG=~/.repo/config.toml

# ── LLM（S1 阶段启用）────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# REPO_LLM_DEFAULT_MODEL=claude-sonnet-4-6
# REPO_MAX_STEPS=20
